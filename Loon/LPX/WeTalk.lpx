#!name=WeTalk
#!desc=WeTalk 获取 Cookie 与自动签到插件
#!author=TG@ZenMoFiShi, Minis
#!homepage=https://github.com/elyndareth-max/box
#!openUrl=https://github.com/elyndareth-max/box/blob/main/Loon/LPX/WeTalk.lpx
#!tag=签到
#!icon=https://raw.githubusercontent.com/fishdown/Icon/master/app/WeTalk.png
#!system=iOS
#!loon_version=3.2.1(372)
#!date=2026-04-21 21:00:00

[Mitm]
hostname = api.wetalkapp.com

[Script]
cron {cron} script-path=https://raw.githubusercontent.com/elyndareth-max/box/main/Loon/Script/WeTalk.js, img-url=https://raw.githubusercontent.com/fishdown/Icon/master/app/WeTalk.png, timeout=60, enable={sw},tag=WeTalk

http-request ^https:\/\/api\.wetalkapp\.com\/app\/queryBalanceAndBonus script-path=https://raw.githubusercontent.com/elyndareth-max/box/main/Loon/Script/WeTalk.js, requires-body=true, timeout=60, img-url=https://raw.githubusercontent.com/fishdown/Icon/master/app/WeTalk.png, enable={sw2},tag=WeTalk Cookie

[Argument]
sw=switch,true,tag=WeTalk Cron,desc=
sw2=switch,false,tag=WeTalk Cookie,desc=
cron = input, "5 */4 * * *", tag=Cron时间, desc=
